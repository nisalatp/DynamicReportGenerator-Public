@startuml Sequence Assign Report
title Workflow: Assigning a Report to a User

actor Client
participant "ReportMaker" as Maker
participant "SavedReport" as DBReport
participant "dynamic_report_user" as Pivot
participant "ReportLog" as DBLog

Client -> Maker : assignReport(reportId, userId, actionByUserId)
activate Maker

Maker -> DBReport : findOrFail(reportId)
activate DBReport
DBReport --> Maker : SavedReport Model
deactivate DBReport

Maker -> Pivot : syncWithoutDetaching([userId])
activate Pivot
Pivot --> Maker : Attached Status
deactivate Pivot

Maker -> Maker : logAction(reportId, actionByUserId, action='assigned', details=['assigned_user_id' => userId])
activate Maker
Maker -> DBLog : create(saved_report_id=reportId, action='assigned', details)
activate DBLog
DBLog --> Maker : ReportLog Model
deactivate DBLog
deactivate Maker

Maker --> Client : void
deactivate Maker

@enduml
