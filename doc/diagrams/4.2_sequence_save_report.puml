@startuml Sequence Save Report
title Workflow: Saving a New Report

actor Client
participant "ReportMaker" as Maker
participant "ReportRequest" as Request
participant "ReportSerializer" as Serializer
participant "SavedReport" as DBReport
participant "ReportLog" as DBLog

Client -> Maker : saveReport(name, request, userId, description)
activate Maker

Maker -> Request : toJson()
activate Request
Request -> Serializer : toJson(request)
activate Serializer
Serializer --> Request : JSON string
deactivate Serializer
Request --> Maker : JSON string
deactivate Request

Maker -> DBReport : create(name, description, payload=JSON, user_id=userId)
activate DBReport
DBReport --> Maker : SavedReport Model (id: 123)
deactivate DBReport

Maker -> Maker : logAction(reportId=123, userId, action='created')
activate Maker
Maker -> DBLog : create(saved_report_id=123, action='created', user_id=userId)
activate DBLog
DBLog --> Maker : ReportLog Model
deactivate DBLog
deactivate Maker

Maker --> Client : SavedReport Model
deactivate Maker

@enduml
