@startuml Virtual Attribute Builder Flow
title Demo App Flow: Virtual Attribute Registration

actor "Software Engineer\n(Admin)" as Admin
participant "VA Playground UI" as UI
participant "VirtualAttributeBuilderController" as Controller
participant "VirtualAttributeCompiler\n(Service)" as Compiler
participant "VirtualAttributeBuilder" as Builder
database "Database" as DB

Admin -> UI : Open Virtual Attribute Tab
activate UI

alt Visual Mode
    Admin -> UI : Select Model & Aggregation (e.g. SUM)
    Admin -> UI : Select Mapped Key
    UI -> Controller : POST /va-builder/compile
    activate Controller
    Controller -> Compiler : compileVisualPayload(JSON)
    activate Compiler
    Compiler --> Controller : SQL Fragment
    deactivate Compiler
    Controller --> UI : SQL Fragment Response
    deactivate Controller
else Advanced Mode
    Admin -> UI : Write Raw SQL Subquery
end

Admin -> UI : Click "Save Virtual Attribute"
UI -> Controller : POST /va-builder/register\n(name, model, sqlFragment, dependencies)
activate Controller

Controller -> Builder : create(name)->forBaseModel()->withSqlFragment()->register()
activate Builder
Builder -> DB : Update/Create Record
activate DB
DB --> Builder : Success
deactivate DB
Builder --> Controller : VirtualAttribute Instance
deactivate Builder

Controller --> UI : Success Response
deactivate Controller

UI --> Admin : Show Success Notification
deactivate UI

@enduml
