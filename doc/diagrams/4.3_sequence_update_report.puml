@startuml Sequence Update Report
title Workflow: Updating an Existing Report

actor Client
participant "ReportMaker" as Maker
participant "ReportRequest" as Request
participant "SavedReport" as DBReport
participant "ReportLog" as DBLog

Client -> Maker : updateReport(reportId, name, request, description, actionByUserId)
activate Maker

Maker -> DBReport : findOrFail(reportId)
activate DBReport
DBReport --> Maker : SavedReport Model
deactivate DBReport

Maker -> Request : toJson()
activate Request
Request --> Maker : JSON string
deactivate Request

Maker -> DBReport : update([name, description, payload=JSON])
activate DBReport
DBReport --> Maker : true
deactivate DBReport

Maker -> Maker : logAction(reportId, actionByUserId, action='updated')
activate Maker
Maker -> DBLog : create(saved_report_id=reportId, action='updated', user_id=actionByUserId)
activate DBLog
DBLog --> Maker : ReportLog Model
deactivate DBLog
deactivate Maker

Maker --> Client : SavedReport Model
deactivate Maker

@enduml
