@startuml Package Diagram
title Dynamic Report Generator - Package Diagram

package "Nisalatp\\DynamicReportGenerator" {
    
    package "Providers" {
        [DynamicReportGeneratorServiceProvider]
    }
    
    package "Facades" {
        [DynamicReport]
    }

    package "Engine" {
        [ReportMaker]
    }

    package "Types (AST & DTOs)" {
        [ReportRequest]
        [VirtualAttributeRequest]
        [FilterNode / FilterGroup / FilterLeaf]
        [Attribute]
        [Aggregate]
        [GroupBy]
        [Sort]
        [ReportSerializer]
        [JoinPlan / JoinStep]
        [ModelLink / ModelInfo]
    }

    package "Builders" {
        [ReportBuilder]
        [FilterBuilder]
        [VirtualAttributeBuilder]
    }

    package "Services" {
        [GovernanceManager]
        [VirtualAttributeManager]
        [VirtualAttributeCompiler]
    }

    package "Registry" {
        [VirtualAttributeRegistry]
    }

    package "Models" {
        [SavedReport]
        [ReportLog]
        [VirtualAttribute]
        [RestrictedModel]
        [AttributeRestriction]
    }

    package "Contracts" {
        [DynamicReportSubject]
    }

    package "Exceptions" {
        [ReportMakerException]
        [ReportMakerSecurityException]
    }

    package "Http\\Requests" {
        [ReportBuilderRequest]
    }
}

package "Illuminate (Laravel Framework)" {
    [Database\\Eloquent\\Model]
    [Database\\Query\\Builder]
    [Support\\ServiceProvider]
    [Support\\Facades\\DB]
}

' === Dependency Arrows ===
Providers --> Engine : "Registers as Singleton"
Facades --> Engine : "Proxies static calls"
Engine --> Types : "Consumes / Generates"
Engine --> Models : "CRUD Operations"
Engine --> Exceptions : "Throws"
Engine --> Registry : "Resolves Virtual Attributes"
Engine --> Contracts : "Polls for subjects"
Services --> Engine : "Delegates to"
Services --> Models : "Queries / Mutates"
Services --> Registry : "Reads from"
Builders --> Types : "Constructs DTOs"
Types --> Exceptions : "Throws on validation"
Models --> Illuminate : "Extends Eloquent Model"
Engine --> Illuminate : "Uses Query Builder & DB"
"Http\\Requests" --> Types : "Parses JSON into DTOs"

@enduml
